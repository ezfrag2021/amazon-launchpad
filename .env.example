# ============================================================================
# Amazon Launchpad - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it's already in .gitignore
# ============================================================================

# ===== Database Configuration (Required) =====
# PostgreSQL connection details
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=amazon_dash
DB_SSLMODE=disable

# Database passwords (URL-encoded)
# Use: python -c "from urllib.parse import quote_plus; print(quote_plus('your_password'))"
LAUNCHPAD_DB_PASSWORD_ENC=your_launchpad_app_password_encoded
MARKET_INTEL_DB_PASSWORD_ENC=your_market_intel_password_encoded
PG_DB_PASSWORD_ENC=your_postgres_password_encoded

# DSNs (built from base vars above - no need to edit)
LAUNCHPAD_DB_DSN=postgresql://launchpad_app:${LAUNCHPAD_DB_PASSWORD_ENC}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${DB_SSLMODE}
MARKET_INTEL_DSN=postgresql://market_intel_writer:${MARKET_INTEL_DB_PASSWORD_ENC}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${DB_SSLMODE}
PG_DSN=postgresql://amazon_dash_user:${PG_DB_PASSWORD_ENC}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${DB_SSLMODE}

# ===== Jungle Scout API (Required for Stage 1) =====
# Get your API key from: https://www.junglescout.com/api/
JUNGLESCOUT_API_KEY_NAME=your_api_key_name
JUNGLESCOUT_API_KEY=your_api_key_here
JUNGLESCOUT_MAX_RETRIES=5
JUNGLESCOUT_MAX_API_CALLS=50

# ===== Google Generative AI (Required for Stage 4) =====
# Path to your Google service account JSON key file
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_JSON=./gen-lang-client-0422857398-6a11b7435ae6.json

# ===== GitHub Configuration (Optional - for CLI) =====
# Personal Access Token for gh CLI commands
# Create at: https://github.com/settings/tokens
# Required scopes: repo (for repository operations)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ===== Launchpad Configuration =====
# Data mode: 'mock' for testing, 'live' for production
LAUNCHPAD_DATA_MODE=mock

# Monthly API call budget (default: 500)
LAUNCHPAD_MONTHLY_API_BUDGET=500

# Log directory
LAUNCHPAD_LOG_DIR=./logs

# ===== Marketplace Configuration =====
# Target marketplaces for UK/EU launches (comma-separated)
MARKETPLACE_TARGETS=UK,DE,FR,IT,ES

# ===== OpenCode Configuration =====
OPENCODE_DISABLE_GLOBAL_CONFIG=true

# ============================================================================
# Setup Instructions:
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values
# 3. Never commit .env to git
# 4. Run: python scripts/validate_launchpad_access.sql to test DB connection
# ============================================================================
