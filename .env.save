# ===== Database Connection =====
DB_HOST=192.168.0.110
DB_PORT=5433
DB_NAME=
DB_SSLMODE=disable

# Primary DSN (URL-encoded password if it has special chars)
LAUNCHPAD_DB_DSN=postgresql://launchpad_app:<LAUNCHPAD_DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>?sslmode=disable

# Fallback DSNs
MARKET_INTEL_DSN=postgresql://market_intel_writer:<MARKET_INTEL_DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>?sslmode=disable
PG_DSN=postgresql://amazon_dash_user:<PG_DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>?sslmode=disable

# ===== Jungle Scout =====
JUNGLESCOUT_API_KEY_NAME=<JUNGLESCOUT_API_KEY_NAME>
JUNGLESCOUT_API_KEY=<JUNGLESCOUT_API_KEY>
JUNGLESCOUT_MAX_RETRIES=5
JUNGLESCOUT_MAX_API_CALLS=50

# ===== Google Generative AI =====
GOOGLE_SERVICE_ACCOUNT_JSON=<GOOGLE_SERVICE_ACCOUNT_JSON_PATH>

# ===== Launchpad-Specific =====
LAUNCHPAD_DATA_MODE=db
LAUNCHPAD_MONTHLY_API_BUDGET=500
LAUNCHPAD_LOG_DIR=/mnt/amazon-launch/logs

# ===== Marketplace Policy =====
MARKETPLACE_TARGETS=UK,DE,FR,IT,ES
